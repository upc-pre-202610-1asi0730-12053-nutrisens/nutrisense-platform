{
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;user=root;password=123456789;database=nutrisense"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://app-sense.nutriproject.xyz"
    ]
  },
  "TokenSettings": {
    "Issuer": "nutrisense-platform",
    "Audience": "nutrisense-clients",
    "ExpiresInMinutes": "1440"
  },
  "OpenWeatherMap": {
    "ApiKey": "",
    "BaseUrl": "https://api.openweathermap.org/data/2.5",
    "GeoBaseUrl": "https://api.openweathermap.org/geo/1.0",
    "CacheMinutes": "10"
  },
  "Usda": {
    "ApiKey": "",
    "BaseUrl": "https://api.nal.usda.gov/fdc/v1"
  },
  "DeepSeek": {
    "ApiKey": "",
    "BaseUrl": "https://api.deepseek.com",
    "Model": "deepseek-chat"
  },
  "Gemini": {
    "ApiKey": "",
    "BaseUrl": "https://generativelanguage.googleapis.com",
    "Model": "gemini-2.5-flash"
  },
  "Seeder": {
    "Enabled": false,
    "Foods": {
      "MinCount": 100,
      "MaxResults": 50,
      "DataType": "Foundation",
      "Queries": [
        "chicken breast", "brown rice", "broccoli", "salmon", "oats",
        "eggs", "banana", "black beans", "greek yogurt", "almonds"
      ]
    },
    "Ingredients": {
      "MinCount": 1
    },
    "Recipes": {
      "MinCount": 20,
      "MaxPerGoal": 10
    }
  }
}
